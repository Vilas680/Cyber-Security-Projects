def is_valid_url(url):
    """Check if the URL format is valid using regex."""
    url_regex = r'^(http|https):\/\/[a-zA-Z0-9-._~:/?#\[\]@!$&\'()*+,;=%]+$'
    return re.match(url_regex, url)

def check_url_virustotal(url):
    """Check URL safety using VirusTotal API."""
    
    if not is_valid_url(url):
        print("Invalid URL format.")
        return None
    
    url_endpoint = "https://www.virustotal.com/api/v3/urls/"
    
    encoded_url = requests.utils.quote(url)
    
    headers = {
        "x-apikey": VIRUSTOTAL_API_KEY
    }
    
    response = requests.get(url_endpoint + encoded_url, headers=headers)
    
    if response.status_code == 200:
        result = response.json()
        if result.get('data'):
            analysis_id = result["data"]["id"]
            print(f"Analysis ID: {analysis_id}")
            return analysis_id
        else:
            print("No analysis result found.")
            return None
    else:
        print(f"Error: {response.status_code} - {response.text}")
        return None

url = "http://example.com"
