def check_website_security():
    url = input("Enter website URL (e.g. https://example.com): ").strip()

   
    if not url.startswith(("http://", "https://")):
        url = "http://" + url  
    parsed_url = urlparse(url)
    hostname = parsed_url.hostname
    scheme = parsed_url.scheme

    if scheme == "https":
        print("\n🔐 HTTPS Website is SECURE")
        results["Secure (HTTPS)"] += 1
        port = 443
        try:
            context = ssl.create_default_context()
            with socket.create_connection((hostname, port), timeout=5) as sock:
                with context.wrap_socket(sock, server_hostname=hostname) as ssock:
                    cert = ssock.getpeercert()
                    tls_version = ssock.version()
                    issuer = dict(x[0] for x in cert.get("issuer", ()))
                    not_before = cert.get("notBefore")
                    not_after = cert.get("notAfter")

                    print(f"• TLS version: {tls_version}")
                    print(f"• Certificate issuer: {issuer.get('organizationName', issuer.get('commonName', 'Unknown'))}")
                    print(f"• Valid from: {not_before}")
                    print(f"• Valid until: {not_after}")

                    if not_after:
                        expire_dt = datetime.strptime(not_after, "%b %d %H:%M:%S %Y %Z")
                        days = (expire_dt - datetime.utcnow()).days
                        print(f"• Days until expiration: {days}")
        except Exception as e:
            print(f"  (Error fetching certificate: {e})")

    else:
        print("\n❌ HTTP Website is NOT SECURE")
        results["Not Secure (HTTP)"] += 1
        print("• Data is sent in **plain text** — anyone can read it.")
        print("• Vulnerable to **Man-in-the-Middle attacks**.")
        print("• No TLS/SSL certificate protection.")
        print("• Website identity cannot be verified.")


def show_summary():
    print("\n📊 Summary of Checked Websites:")
    for status, count in results.items():
        print(f"• {status}: {count}")

    labels = list(results.keys())
    sizes = list(results.values())
    colors = ["#4CAF50", "#F44336"] 
    # Green for secure, Red for insecure

    plt.pie(sizes, labels=labels, autopct="%1.1f%%", startangle=90, colors=colors)
    plt.axis("equal")
    plt.title("Website Security Status")
    plt.show()

