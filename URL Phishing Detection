def is_https(url):
    return url.lower().startswith("https://")

def check_ssl_certificate(url):
    """Check SSL certificate validity and expiration."""
    try:
        parsed_url = urlparse(url)
        hostname = parsed_url.hostname
        port = 443

        ctx = ssl.create_default_context()
        with socket.create_connection((hostname, port), timeout=5) as sock:
            with ctx.wrap_socket(sock, server_hostname=hostname) as ssock:
                cert = ssock.getpeercert()
                exp_date_str = cert['notAfter']
                exp_date = datetime.strptime(exp_date_str, "%b %d %H:%M:%S %Y %Z")
                days_remaining = (exp_date - datetime.utcnow()).days

                if days_remaining < 0:
                    return (False, f"Expired {abs(days_remaining)} days ago")
                else:
                    return (True, f"Valid, expires in {days_remaining} days")
    except Exception as e:
        return (False, f"SSL Check Failed: {e}")

def check_tls_version(url):
    """Check TLS version."""
    try:
        parsed_url = urlparse(url)
        hostname = parsed_url.hostname
        port = 443

        ctx = ssl.create_default_context()
        with socket.create_connection((hostname, port), timeout=5) as sock:
            with ctx.wrap_socket(sock, server_hostname=hostname) as ssock:
                return ssock.version()
    except Exception:
        return "Unknown"

def check_security_headers(url):
    """Check important HTTP security headers."""
    try:
        response = requests.get(url, timeout=5, verify=False)
        headers = response.headers
        required_headers = [
            "Content-Security-Policy",
            "X-Frame-Options",
            "X-Content-Type-Options",
            "Strict-Transport-Security",
            "Referrer-Policy"
        ]
        present = [h for h in required_headers if h in headers]
        missing = [h for h in required_headers if h not in headers]
        return (present, missing)
    except Exception as e:
        return ([], [f"Header Check Failed: {e}"])

def virustotal_scan(url):
    """Check URL reputation using VirusTotal API."""
    try:
        headers = {"x-apikey": VIRUSTOTAL_API_KEY}
        response = requests.post(
            "https://www.virustotal.com/api/v3/urls",
            headers=headers,
            data={"url": url}
        )
        if response.status_code == 200:
            analysis_url = f"https://www.virustotal.com/gui/url/{response.json()['data']['id']}"
            return f"Scan submitted. Check results: {analysis_url}"
        else:
            return f"VirusTotal API Error: {response.status_code} - {response.text}"
    except Exception as e:
        return f"VirusTotal Check Failed: {e}"

